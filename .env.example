# HESES AI Assistant server-side configuration
# 1. Create an API key at https://platform.openai.com/api-keys
# 2. Copy this file to .env
# 3. Replace the placeholder below with your real key
# 4. Restart HESES with npm run dev or npm run dev:all
#
# Never expose this value in React or any VITE_* variable.
OPENAI_API_KEY=sk-your-server-side-key

# Optional model override for the HESES assistant.
HESES_OPENAI_MODEL=gpt-4.1-mini

# Optional standalone assistant server port used by npm run assistant.
HESES_ASSISTANT_PORT=8787

# Optional private web access code for deployed validation versions.
# Leave empty locally if you do not want the login screen.
HESES_ACCESS_CODE=change-this-private-code
